# ====================================================================
# DoTalk Production Environment Configuration Reference (.env.example)
# ====================================================================

# Node environment mode
NODE_ENV=production

# Server port configuration
PORT=

# MONGODB_URI: Required for persistent Atlas MongoDB database storage.
# Set up a real live cluster or credential-secured replica set URI for persistent data.
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/dotalk
MONGODB_URI=""

# ====================================================================
# Resend API Notification Settings (Bypasses SMTP port blocking entirely!)
# ====================================================================

# RESEND_API_KEY: Official API access key from your Resend account dashboard (e.g. re_123456789)
RESEND_API_KEY=""

# RESEND_FROM_EMAIL: The active verified sender email address configured on your Resend dashboard.
# (e.g. no-reply@yourdomain.com or onboarding@resend.dev)
RESEND_FROM_EMAIL=""

# SMTP_FROM_NAME: Friendly sender name shown to recipients in their inboxes.
SMTP_FROM_NAME="DoTalk Messenger"

# ====================================================================
# Client & Server URL Binding Settings (For multi-network/device deployment)
# ====================================================================

# FRONTEND_URL: Base URL of your web frontend client (e.g. https://do-talk-ivory.vercel.app or similar)
# Used by the backend to configure secure CORS origins.
FRONTEND_URL=""

# VITE_API_URL: Unified gateway URL pointing to your backend services (e.g. https://dotalk-production.up.railway.app)
# This single variable is used by both frontend and mobile apps for REST API queries and Socket.IO.
# (No separate WS_URL/VITE_WS_URL variables are required, avoiding configuration out-of-sync risks!)
VITE_API_URL=""


